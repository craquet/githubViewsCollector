# Required: GitHub personal access token with 'repo' scope
GITHUB_TOKEN=ghp_your_token_here

# Required: Comma-separated list of repositories (owner/repo)
GITHUB_REPOS=owner1/repo1,owner2/repo2

# Optional: Cron schedule for collection (default: every 6 hours)
CRON_SCHEDULE=0 */6 * * *

# Optional: Port for the Prometheus /metrics endpoint (default: 9091)
METRICS_PORT=9091

# Optional: GitHub API base URL (for GitHub Enterprise)
GITHUB_API_URL=https://api.github.com
